<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ title }}</title>
<style>
  :root {
    --bg: {{ theme.background }};
    --fg: {{ theme.foreground }};
    --grid: {{ theme.grid_color }};
    --accent: {{ theme.accent }};
    --card-bg: color-mix(in srgb, var(--bg) 96%, var(--fg) 4%);
    --hover-bg: color-mix(in srgb, var(--bg) 92%, var(--fg) 8%);
    --critical-bg: #fbdada; --critical-fg: #9c1c1c;
    --warning-bg: #fdeecb; --warning-fg: #94620a;
    --info-bg: #dbe8fd; --info-fg: #1d4c9c;
    --success-bg: #d4edda; --success-fg: #155724;
  }
  @media (prefers-color-scheme: dark) {
    /* If the theme is explicitly light, this might clash, but we'll try to keep it general */
  }
  
  * { box-sizing: border-box; }
  body {
    margin: 0;
    font-family: {{ theme.font_family }}, "Inter", sans-serif;
    background: var(--bg);
    color: var(--fg);
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
  }
  a { color: var(--accent); text-decoration: none; }
  a:hover { text-decoration: underline; }
  
  .layout { display: flex; min-height: 100vh; }
  
  nav.sidebar {
    width: 260px;
    flex-shrink: 0;
    border-right: 1px solid var(--grid);
    padding: 30px 20px;
    position: sticky;
    top: 0;
    height: 100vh;
    overflow-y: auto;
    background: color-mix(in srgb, var(--bg) 98%, var(--fg) 2%);
  }
  nav.sidebar h2 { font-size: 16px; margin: 0 0 20px; font-weight: 700; letter-spacing: -0.02em; }
  nav.sidebar a {
    display: block;
    padding: 8px 12px;
    border-radius: 6px;
    color: color-mix(in srgb, var(--fg) 80%, transparent);
    font-size: 14px;
    margin-bottom: 4px;
    transition: all 0.2s ease;
  }
  nav.sidebar a:hover { background: var(--hover-bg); color: var(--fg); transform: translateX(2px); }
  
  main { flex: 1; padding: 40px 60px 100px; max-width: 1280px; }
  
  header.report-header { 
    margin-bottom: 40px; 
    padding-bottom: 30px;
    border-bottom: 1px solid var(--grid);
  }
  header.report-header h1 { 
    margin: 0 0 10px; 
    font-size: 36px; 
    font-weight: 800;
    letter-spacing: -0.03em;
    background: linear-gradient(135deg, var(--fg), var(--accent));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  header.report-header .meta { color: color-mix(in srgb, var(--fg) 60%, transparent); font-size: 14px; }
  
  section { margin-bottom: 60px; }
  section > h2 {
    font-size: 24px;
    font-weight: 700;
    letter-spacing: -0.02em;
    padding-bottom: 12px;
    margin-bottom: 24px;
    display: flex;
    align-items: center;
    gap: 12px;
  }
  section > h2::after {
    content: "";
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg, var(--accent) 0%, var(--grid) 100%);
    opacity: 0.5;
  }
  
  /* Health Gauge */
  .health-container {
    display: flex;
    align-items: center;
    gap: 40px;
    background: var(--card-bg);
    border: 1px solid var(--grid);
    border-radius: 16px;
    padding: 30px;
    margin-bottom: 30px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.03);
  }
  .gauge {
    position: relative;
    width: 120px;
    height: 120px;
    border-radius: 50%;
    background: conic-gradient(var(--accent) calc(var(--score) * 1%), var(--grid) 0);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .gauge::before {
    content: "";
    position: absolute;
    width: 100px;
    height: 100px;
    background: var(--card-bg);
    border-radius: 50%;
  }
  .gauge .score {
    position: relative;
    font-size: 32px;
    font-weight: 800;
    color: var(--fg);
  }
  .health-details h3 { margin: 0 0 10px; font-size: 22px; }
  .health-details p { margin: 0 0 16px; color: color-mix(in srgb, var(--fg) 70%, transparent); }
  .health-metrics {
    display: flex;
    gap: 20px;
    flex-wrap: wrap;
  }
  .metric-pill {
    background: var(--hover-bg);
    padding: 6px 12px;
    border-radius: 20px;
    font-size: 12px;
    font-weight: 600;
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .metric-pill span { color: var(--accent); }

  /* Cards */
  .cards { 
    display: grid; 
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); 
    gap: 20px; 
    margin-bottom: 30px; 
  }
  .card {
    border: 1px solid var(--grid);
    border-radius: 12px;
    padding: 20px;
    background: var(--card-bg);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .card:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.04);
  }
  .card .value { font-size: 28px; font-weight: 800; margin-bottom: 4px; letter-spacing: -0.02em; }
  .card .label { font-size: 13px; color: color-mix(in srgb, var(--fg) 60%, transparent); font-weight: 600; text-transform: uppercase; letter-spacing: .05em; }

  /* Insights */
  .insights-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
  }
  .insight-card {
    border: 1px solid var(--grid);
    border-radius: 12px;
    padding: 16px 20px;
    background: var(--card-bg);
    border-left-width: 4px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .insight-card.highlight { border-left-color: #10b981; }
  .insight-card.observation { border-left-color: #3b82f6; }
  .insight-card.warning { border-left-color: #f59e0b; }
  
  .insight-header { display: flex; align-items: center; justify-content: space-between; }
  .insight-title { font-weight: 700; font-size: 16px; margin: 0; }
  .insight-desc { margin: 0; font-size: 14px; color: color-mix(in srgb, var(--fg) 80%, transparent); }
  
  /* Tables */
  .table-container {
    overflow-x: auto;
    border-radius: 12px;
    border: 1px solid var(--grid);
    margin-bottom: 24px;
  }
  table { border-collapse: collapse; width: 100%; font-size: 13px; }
  th, td { text-align: left; padding: 12px 16px; border-bottom: 1px solid var(--grid); }
  th { 
    background: var(--hover-bg); 
    font-weight: 600; 
    text-transform: uppercase;
    font-size: 11px;
    letter-spacing: 0.05em;
    color: color-mix(in srgb, var(--fg) 70%, transparent);
  }
  tr:last-child td { border-bottom: none; }
  tr:hover { background: color-mix(in srgb, var(--bg) 98%, var(--fg) 2%); }
  
  /* Badges */
  .badge { display: inline-block; padding: 4px 10px; border-radius: 20px; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; }
  .badge.critical { background: var(--critical-bg); color: var(--critical-fg); }
  .badge.warning { background: var(--warning-bg); color: var(--warning-fg); }
  .badge.info, .badge.observation { background: var(--info-bg); color: var(--info-fg); }
  .badge.highlight { background: var(--success-bg); color: var(--success-fg); }
  
  /* Column Details */
  details.column-card {
    border: 1px solid var(--grid);
    border-radius: 12px;
    margin-bottom: 16px;
    background: var(--card-bg);
    overflow: hidden;
  }
  details.column-card > summary {
    cursor: pointer;
    font-weight: 700;
    font-size: 16px;
    padding: 16px 20px;
    list-style: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
    transition: background 0.2s ease;
  }
  details.column-card > summary:hover { background: var(--hover-bg); }
  details.column-card > summary::-webkit-details-marker { display: none; }
  .col-header-info { display: flex; align-items: center; gap: 16px; font-weight: 400; font-size: 13px; color: color-mix(in srgb, var(--fg) 60%, transparent); }
  .type-badge { background: var(--hover-bg); padding: 4px 10px; border-radius: 6px; font-family: monospace; color: var(--fg); }
  
  .col-body { padding: 20px; border-top: 1px solid var(--grid); background: var(--bg); }
  .stat-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 16px; margin-bottom: 24px; }
  .stat-item { border-left: 2px solid var(--grid); padding-left: 12px; }
  .stat-item .lbl { font-size: 11px; text-transform: uppercase; color: color-mix(in srgb, var(--fg) 60%, transparent); font-weight: 600; margin-bottom: 4px; }
  .stat-item .val { font-size: 15px; font-weight: 600; font-family: monospace; }
  
  /* Progress bars */
  .progress-wrap { width: 100px; height: 6px; background: var(--grid); border-radius: 3px; overflow: hidden; display: inline-block; vertical-align: middle; margin-left: 8px; }
  .progress-bar { height: 100%; background: var(--accent); }
  .progress-bar.danger { background: #ef4444; }
  .progress-bar.warning { background: #f59e0b; }
  
  /* Images */
  .image-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(360px, 1fr)); gap: 24px; margin-top: 20px; }
  .image-grid figure { margin: 0; border: 1px solid var(--grid); border-radius: 12px; padding: 16px; background: var(--card-bg); }
  .image-grid img { width: 100%; height: auto; border-radius: 6px; display: block; }
  .image-grid figcaption { font-size: 13px; font-weight: 600; color: color-mix(in srgb, var(--fg) 70%, transparent); margin-top: 12px; text-align: center; }
  
  .empty-note { color: color-mix(in srgb, var(--fg) 60%, transparent); font-style: italic; font-size: 14px; padding: 20px; background: var(--card-bg); border-radius: 8px; text-align: center; }
  
  .suggestion { 
    padding: 16px 20px; 
    border-left: 4px solid var(--accent); 
    background: color-mix(in srgb, var(--bg) 96%, var(--accent) 4%); 
    margin-bottom: 12px; 
    border-radius: 0 12px 12px 0; 
    font-size: 14px;
  }
  .suggestion .action { font-weight: 800; text-transform: uppercase; font-size: 12px; color: var(--accent); display: block; margin-bottom: 4px; }
  
  footer { color: color-mix(in srgb, var(--fg) 50%, transparent); font-size: 13px; padding: 30px 60px; border-top: 1px solid var(--grid); text-align: center; }
  code { background: var(--hover-bg); padding: 2px 6px; border-radius: 4px; font-family: monospace; font-size: 13px; }
  
  @media print {
    nav.sidebar { display: none; }
    main { padding: 0; max-width: 100%; }
    .layout { display: block; }
    .card, .insight-card, details.column-card { break-inside: avoid; }
    details.column-card[open] { display: block; }
  }
</style>
</head>
<body>
<div class="layout">
  <nav class="sidebar">
    <h2>{{ title }}</h2>
    <a href="#overview">Overview & Health</a>
    <a href="#insights">Automated Insights</a>
    <a href="#quality">Data Quality</a>
    <a href="#memory">Memory Analysis</a>
    <a href="#missing">Missing Values</a>
    <a href="#stats">Descriptive Stats</a>
    <a href="#columns">Column Statistics</a>
    <a href="#correlation">Correlations</a>
    <a href="#outliers">Outliers</a>
    <a href="#bivariate">Bivariate Analysis</a>
    <a href="#multivariate">Multivariate Analysis</a>
    {% if timeseries_plots %}<a href="#timeseries">Time Series</a>{% endif %}
    {% if target_analysis %}<a href="#target">Target Analysis</a>{% endif %}
    {% if hopkins_statistic or ab_testing or drift or timeseries_changepoints %}<a href="#advanced">Advanced Analytics</a>{% endif %}
    {% if statistical_tests %}<a href="#tests">Statistical Testing</a>{% endif %}
    <a href="#features">Feature Engineering</a>
  </nav>
  <main>
    <header class="report-header" id="overview">
      <h1>{{ title }}</h1>
      <div class="meta">Generated {{ generated_at }} &middot; omni_eda v{{ version }}</div>
    </header>

    {% if health_score %}
    <section id="health">
      <div class="health-container">
        <div class="gauge" style="--score: {{ health_score.score }}">
          <div class="score">{{ health_score.score|round|int }}</div>
        </div>
        <div class="health-details">
          <h3>Dataset Health: {{ health_score.grade }} ({{ health_score.label }})</h3>
          <p>The health score is a weighted combination of completeness, consistency, validity, uniqueness, and accuracy.</p>
          <div class="health-metrics">
            <div class="metric-pill">Completeness: <span>{{ health_score.dimensions.completeness }}</span></div>
            <div class="metric-pill">Consistency: <span>{{ health_score.dimensions.consistency }}</span></div>
            <div class="metric-pill">Validity: <span>{{ health_score.dimensions.validity }}</span></div>
            <div class="metric-pill">Uniqueness: <span>{{ health_score.dimensions.uniqueness }}</span></div>
            <div class="metric-pill">Accuracy: <span>{{ health_score.dimensions.accuracy }}</span></div>
          </div>
        </div>
      </div>
    </section>
    {% endif %}

    <section id="overview-cards">
      <div class="cards">
        <div class="card"><div class="value">{{ '{:,}'.format(overview.n_rows) }}</div><div class="label">Rows</div></div>
        <div class="card"><div class="value">{{ overview.n_columns }}</div><div class="label">Columns</div></div>
        <div class="card"><div class="value">{{ overview.memory_human }}</div><div class="label">Memory</div></div>
        <div class="card"><div class="value">{{ overview.n_duplicate_rows }}</div><div class="label">Duplicate rows</div></div>
        <div class="card"><div class="value">{{ '%.1f'|format(overview.missing_pct) }}%</div><div class="label">Missing cells</div></div>
        <div class="card"><div class="value">{{ quality.n_critical }}</div><div class="label">Critical issues</div></div>
      </div>
    
      {% if data_sample_head %}
      <h3 style="margin-top: 30px;">Data Sample (Head)</h3>
      <div class="table-container">
        <table>
          <tr>
            {% for col in data_sample_columns %}<th>{{ col }}</th>{% endfor %}
          </tr>
          {% for row in data_sample_head %}
          <tr>
            {% for col in data_sample_columns %}<td>{{ row[col] }}</td>{% endfor %}
          </tr>
          {% endfor %}
        </table>
      </div>
      {% endif %}
    </section>

    {% if insights %}
    <section id="insights">
      <h2>Automated Insights</h2>
      <div class="insights-grid">
        {% for insight in insights %}
        <div class="insight-card {{ insight.severity }}">
          <div class="insight-header">
            <h4 class="insight-title">{{ insight.title }}</h4>
            <span class="badge {{ insight.severity }}">{{ insight.category }}</span>
          </div>
          <p class="insight-desc">{{ insight.description }}</p>
        </div>
        {% endfor %}
      </div>
    </section>
    {% endif %}

    <section id="quality">
      <h2>Data Quality Report</h2>
      {% if quality.issues %}
      <div class="table-container">
        <table>
          <tr><th>Severity</th><th>Category</th><th>Column</th><th>Message</th></tr>
          {% for issue in quality.issues %}
          <tr>
            <td><span class="badge {{ issue.severity }}">{{ issue.severity }}</span></td>
            <td>{{ issue.category }}</td>
            <td>{{ issue.column or '-' }}</td>
            <td>{{ issue.message }}</td>
          </tr>
          {% endfor %}
        </table>
      </div>
      {% else %}
      <p class="empty-note">No data quality issues detected.</p>
      {% endif %}

      {% if quality_scorecard %}
      <h3 style="margin-top: 30px;">Quality Scorecard</h3>
      <div class="table-container">
        <table>
          <tr><th>Column</th><th>Missing%</th><th>Constant</th><th>High Cardinality</th><th>High Skew</th><th>Has Outliers</th><th>Quality Score</th></tr>
          {% for row in quality_scorecard %}
          <tr>
            <td><code>{{ row.column }}</code></td>
            <td>{{ row.missing_pct }}%</td>
            <td>{% if row.is_constant %}Yes{% else %}No{% endif %}</td>
            <td>{% if row.is_high_cardinality %}Yes{% else %}No{% endif %}</td>
            <td>{% if row.is_highly_skewed %}Yes{% else %}No{% endif %}</td>
            <td>{% if row.has_outliers %}Yes{% else %}No{% endif %}</td>
            <td><strong>{{ row.score }}</strong>/100</td>
          </tr>
          {% endfor %}
        </table>
      </div>
      {% endif %}
    </section>

    {% if memory_analysis %}
    <section id="memory">
      <h2>Memory Optimization Analysis</h2>
      <p>Current usage: <strong>{{ memory_analysis.current_memory_human }}</strong>. 
         Potential savings: <strong>{{ memory_analysis.total_savings_human }} ({{ memory_analysis.savings_pct }}%)</strong>.</p>
      
      {% set opt_cols = [] %}
      {% for col in memory_analysis.columns %}
        {% if col.can_optimize %}{% set _ = opt_cols.append(col) %}{% endif %}
      {% endfor %}

      {% if opt_cols %}
      <div class="table-container">
        <table>
          <tr><th>Column</th><th>Current Dtype</th><th>Recommended Dtype</th><th>Savings (Bytes)</th></tr>
          {% for col in opt_cols %}
          <tr>
            <td><code>{{ col.column }}</code></td>
            <td><code>{{ col.current_dtype }}</code></td>
            <td><code style="color:var(--accent)">{{ col.recommended_dtype }}</code></td>
            <td>{{ '{:,}'.format(col.savings_bytes) }}</td>
          </tr>
          {% endfor %}
        </table>
      </div>
      {% else %}
      <p class="empty-note">All columns are currently optimally typed. No obvious memory savings available.</p>
      {% endif %}
    </section>
    {% endif %}

    <section id="missing">
      <h2>Missing Value Analysis</h2>
      <p>{{ missing.columns_with_missing }} column(s) have missing values &middot;
         {{ '{:,}'.format(missing.rows_with_any_missing) }} row(s) contain at least one missing value &middot;
         {{ '%.2f'|format(missing.overall_missing_pct) }}% of all cells are missing.</p>
      
      {% if missing.patterns is defined and not missing.patterns.empty %}
      <h3>Common Missingness Patterns</h3>
      <div class="table-container">
        <table>
          <tr><th>Missing Columns Combination</th><th>Row Count</th><th>% of Rows</th></tr>
          {% for i, row in missing.patterns.iterrows() %}
          <tr>
            <td><code>{{ row.pattern }}</code></td>
            <td>{{ '{:,}'.format(row.n_rows) }}</td>
            <td>{{ '%.2f'|format(row.pct_rows) }}%</td>
          </tr>
          {% endfor %}
        </table>
      </div>
      {% endif %}

      <div class="image-grid">
        {% for name, img in missing_plots.items() %}
        <figure><img src="{{ img }}" loading="lazy"><figcaption>{{ name }}</figcaption></figure>
        {% endfor %}
      </div>
    </section>


    <section id="stats">
      <h2>Descriptive Statistics Summary</h2>
      {% if numeric_summary_table %}
      <h3>Numeric Summary</h3>
      <div class="table-container">
        <table>
          <tr><th>Column</th><th>Count</th><th>Missing%</th><th>Mean</th><th>Std</th><th>Min</th><th>Median</th><th>Max</th><th>Skewness</th><th>Distribution</th></tr>
          {% for row in numeric_summary_table %}
          <tr>
            <td><code>{{ row.column }}</code></td>
            <td>{{ '{:,}'.format(row.count) }}</td>
            <td>{{ row.missing_pct }}%</td>
            <td>{{ '%.4g'|format(row.mean) if row.mean is not none else '-' }}</td>
            <td>{{ '%.4g'|format(row.std) if row.std is not none else '-' }}</td>
            <td>{{ '%.4g'|format(row.min) if row.min is not none else '-' }}</td>
            <td>{{ '%.4g'|format(row.median) if row.median is not none else '-' }}</td>
            <td>{{ '%.4g'|format(row.max) if row.max is not none else '-' }}</td>
            <td>{{ '%.4g'|format(row.skewness) if row.skewness is not none else '-' }}</td>
            <td>{{ row.distribution }}</td>
          </tr>
          {% endfor %}
        </table>
      </div>
      {% endif %}
      
      {% if categorical_summary_table %}
      <h3>Categorical Summary</h3>
      <div class="table-container">
        <table>
          <tr><th>Column</th><th>Count</th><th>Missing%</th><th>Unique</th><th>Top Value</th><th>Top%</th><th>Entropy</th></tr>
          {% for row in categorical_summary_table %}
          <tr>
            <td><code>{{ row.column }}</code></td>
            <td>{{ '{:,}'.format(row.count) }}</td>
            <td>{{ row.missing_pct }}%</td>
            <td>{{ row.n_unique }}</td>
            <td>{{ row.top_value }}</td>
            <td>{{ row.top_value_pct }}%</td>
            <td>{{ '%.4g'|format(row.entropy) if row.entropy is not none else '-' }}</td>
          </tr>
          {% endfor %}
        </table>
      </div>
      {% endif %}
    </section>

    <section id="columns">
      <h2>Column Statistics &amp; Distributions</h2>
      {% for col in columns %}
      <details class="column-card">
        <summary>
          <div style="display:flex; align-items:center; gap: 12px;">
            <span>{{ col.name }}</span>
            <span class="type-badge">{{ col.base_type }}</span>
          </div>
          <div class="col-header-info">
            {% if col.semantic_type %}<span>Semantic: {{ col.semantic_type }}</span>{% endif %}
            <span>Unique: {{ '{:,}'.format(col.n_unique) }}</span>
            <span>Missing: {{ '%.1f'|format(col.missing_pct) }}% 
              <div class="progress-wrap"><div class="progress-bar {% if col.missing_pct > 50 %}danger{% elif col.missing_pct > 10 %}warning{% endif %}" style="width:{{ col.missing_pct }}%"></div></div>
            </span>
          </div>
        </summary>
        <div class="col-body">
          <div class="stat-grid">
            {% for k, v in col.stats.items() %}
            {% if k not in ('percentiles', 'top_values', 'top_words', 'top_chars', 'rare_categories') and v is not none %}
            <div class="stat-item">
              <div class="lbl">{{ k.replace('_', ' ') }}</div>
              <div class="val">{% if v is float %}{{ '%.4g'|format(v) }}{% else %}{{ v }}{% endif %}</div>
            </div>
            {% endif %}
            {% endfor %}
          </div>
          {% if col.plots %}
          <div class="image-grid" style="margin-top: 0;">
            {% for name, img in col.plots.items() %}
            <figure><img src="{{ img }}" loading="lazy"><figcaption>{{ name.replace('_', ' ').title() }}</figcaption></figure>
            {% endfor %}
          </div>
          {% endif %}
        </div>
      </details>
      {% endfor %}
    </section>

    <section id="correlation">
      <h2>Correlation &amp; Association Analysis</h2>
      {% if correlation.high_pairs %}
      <div class="table-container">
        <table>
          <tr><th>Column A</th><th>Column B</th><th>Value (r)</th></tr>
          {% for p in correlation.high_pairs %}
          <tr><td><code>{{ p.col_a }}</code></td><td><code>{{ p.col_b }}</code></td><td><strong>{{ '%.3f'|format(p.value) }}</strong></td></tr>
          {% endfor %}
        </table>
      </div>
      {% else %}
      <p class="empty-note">No highly correlated pairs found above the configured threshold.</p>
      {% endif %}
    </section>

    <section id="outliers">
      <h2>Outlier Detection</h2>
      {% if outliers %}
      <div class="table-container">
        <table>
          <tr><th>Column / Scope</th><th>Detection Method</th><th>Outlier Count</th><th>% of rows</th></tr>
          {% for row in outliers %}
          <tr>
            <td><code>{{ row.column }}</code></td>
            <td>{{ row.method.replace('_', ' ').title() }}</td>
            <td>{{ '{:,}'.format(row.n_outliers) }}</td>
            <td>{{ '%.2f'|format(row.pct_outliers) }}%</td>
          </tr>
          {% endfor %}
        </table>
      </div>
      
      {% if outlier_explanations %}
      <h3>Multivariate Outlier Explanations (Top 10)</h3>
      {% for method, explanations in outlier_explanations.items() %}
      <h4>Method: {{ method.replace('_', ' ').title() }}</h4>
      <div class="table-container">
        <table>
          <tr><th>Row Index</th><th>Top Feature Deviations</th></tr>
          {% for exp in explanations %}
          <tr>
            <td><code>{{ exp.row_index }}</code></td>
            <td>
              <ul style="margin: 0; padding-left: 20px;">
              {% for reason in exp.reasons %}
                <li>{{ reason }}</li>
              {% endfor %}
              </ul>
            </td>
          </tr>
          {% endfor %}
        </table>
      </div>
      {% endfor %}
      {% endif %}

      {% else %}
      <p class="empty-note">No numeric columns available for outlier detection.</p>
      {% endif %}
    </section>

    <section id="bivariate">
      <h2>Bivariate Analysis</h2>
      {% if bivariate_plots %}
      <div class="image-grid">
        {% for name, img in bivariate_plots.items() %}
        <figure><img src="{{ img }}" loading="lazy"><figcaption>{{ name.replace('_', ' ') }}</figcaption></figure>
        {% endfor %}
      </div>
      {% else %}
      <p class="empty-note">No bivariate plots generated (check configuration or data types).</p>
      {% endif %}
    </section>

    <section id="multivariate">
      <h2>Multivariate Analysis</h2>
      {% if multivariate_plots %}
      <div class="image-grid">
        {% for name, img in multivariate_plots.items() %}
        <figure><img src="{{ img }}" loading="lazy"><figcaption>{{ name.replace('_', ' ').title() }}</figcaption></figure>
        {% endfor %}
      </div>
      {% else %}
      <p class="empty-note">No multivariate plots generated.</p>
      {% endif %}
    </section>

    {% if timeseries_plots %}
    <section id="timeseries">
      <h2>Time Series Analysis</h2>
      {% for col, plots in timeseries_plots.items() %}
      <h3>Target: <code>{{ col }}</code></h3>
      <div class="image-grid">
        {% for name, img in plots.items() %}
        <figure><img src="{{ img }}" loading="lazy"><figcaption>{{ name.replace('_', ' ').title() }}</figcaption></figure>
        {% endfor %}
      </div>
      {% endfor %}
    </section>
    {% endif %}

    {% if target_analysis %}
    <section id="target">
      <h2>Target Analysis: <code>{{ target_analysis.target }}</code></h2>
      {% if target_analysis.class_imbalance %}
      <h3>Class balance</h3>
      <div class="table-container">
        <table>
          <tr><th>Class</th><th>Count</th><th>Proportion</th></tr>
          {% for k, v in target_analysis.class_imbalance.counts.items() %}
          <tr><td><code>{{ k }}</code></td><td>{{ '{:,}'.format(v) }}</td><td>{{ '%.1f'|format(target_analysis.class_imbalance.proportions[k] * 100) }}%</td></tr>
          {% endfor %}
        </table>
      </div>
      {% endif %}

      {% if target_analysis.feature_associations %}
      <h3>Feature associations with target</h3>
      <div class="table-container">
        <table>
          <tr><th>Column</th><th>Test</th><th>Statistic</th><th>p-value</th></tr>
          {% for a in target_analysis.feature_associations %}
          <tr>
            <td><code>{{ a.column }}</code></td><td>{{ a.test }}</td>
            <td>{{ '%.4f'|format(a.f_statistic) if a.f_statistic is defined else ('%.4f'|format(a.chi2) if a.chi2 is defined else '%.4f'|format(a.value)) }}</td>
            <td>{{ '%.4g'|format(a.p_value) if a.p_value is defined else '-' }}</td>
          </tr>
          {% endfor %}
        </table>
      </div>
      {% endif %}

      {% if target_analysis.feature_importance_table %}
      <h3>Feature importance (Random Forest + Mutual Info)</h3>
      <div class="table-container">
        <table>
          <tr><th>Feature</th><th>RF importance</th><th>Mutual information</th></tr>
          {% for row in target_analysis.feature_importance_table %}
          <tr>
            <td><code>{{ row.feature }}</code></td>
            <td>
              {{ '%.4f'|format(row.importance_rf) }}
              <div class="progress-wrap"><div class="progress-bar" style="width:{{ row.importance_rf * 100 }}%"></div></div>
            </td>
            <td>{{ '%.4f'|format(row.mutual_information) }}</td>
          </tr>
          {% endfor %}
        </table>
      </div>
      {% endif %}

      {% if target_analysis.curves %}
      <h3>Baseline classifier evaluation {% if target_analysis.curves.roc_auc %}(ROC AUC = {{ '%.3f'|format(target_analysis.curves.roc_auc) }}){% endif %}</h3>
      <div class="image-grid">
        {% if target_analysis.curves.roc_curve %}<figure><img src="{{ target_analysis.curves.roc_curve }}"><figcaption>ROC curve</figcaption></figure>{% endif %}
        {% if target_analysis.curves.pr_curve %}<figure><img src="{{ target_analysis.curves.pr_curve }}"><figcaption>Precision-Recall curve</figcaption></figure>{% endif %}
        {% if target_analysis.curves.lift_chart %}<figure><img src="{{ target_analysis.curves.lift_chart }}"><figcaption>Lift chart</figcaption></figure>{% endif %}
      </div>
      {% endif %}
    </section>
    {% endif %}

    {% if hopkins_statistic or ab_testing or drift or timeseries_changepoints %}
    <section id="advanced">
      <h2>Advanced Analytics</h2>
      
      {% if hopkins_statistic %}
      <h3>Clustering Tendency</h3>
      <p><strong>Hopkins Statistic:</strong> {{ '%.3f'|format(hopkins_statistic) }}</p>
      <p style="font-size:13px; color:var(--fg); opacity:0.8;">Values ~0.5 mean the data is uniformly distributed (no meaningful clusters). Values >0.75 indicate a high tendency to cluster.</p>
      {% endif %}
      
      {% if drift %}
      <h3>Data Drift Analysis</h3>
      <p>Compared reference dataset ({{ '{:,}'.format(drift.reference_rows) }} rows) vs current dataset ({{ '{:,}'.format(drift.current_rows) }} rows).</p>
      <div class="table-container">
        <table>
          <tr><th>Feature</th><th>Type</th><th>Drift Status</th><th>PSI</th><th>KS Stat</th><th>KS p-value</th></tr>
          {% for d in drift.details %}
          <tr>
            <td><code>{{ d.column }}</code></td>
            <td>{{ d.type }}</td>
            <td><span class="badge {% if d.drift_status == 'Severe Drift' %}critical{% elif d.drift_status == 'Moderate Drift' %}warning{% else %}highlight{% endif %}">{{ d.drift_status }}</span></td>
            <td>{{ '%.3f'|format(d.psi) }}</td>
            <td>{{ '%.3f'|format(d.ks_stat) if d.ks_stat is not none else '-' }}</td>
            <td>{{ '%.4f'|format(d.ks_pvalue) if d.ks_pvalue is not none else '-' }}</td>
          </tr>
          {% endfor %}
        </table>
      </div>
      {% endif %}
      
      {% if ab_testing %}
      <h3>A/B Testing (Treatment: <code>{{ ab_testing.treatment_column }}</code>)</h3>
      <div class="table-container">
        <table>
          <tr><th>Metric</th><th>p-value (T-Test)</th><th>Effect Size (Cohen's d)</th><th>Significant?</th></tr>
          {% for res in ab_testing.results %}
          <tr>
            <td><code>{{ res.metric }}</code></td>
            <td>{{ '%.4g'|format(res.p_value_t) }}</td>
            <td>{{ '%.3f'|format(res.cohens_d) if res.cohens_d is not none else '-' }} ({{ res.effect_size }})</td>
            <td>
              {% if res.significant %}
              <span class="badge highlight">Yes</span>
              {% else %}
              <span class="badge info">No</span>
              {% endif %}
            </td>
          </tr>
          {% endfor %}
        </table>
      </div>
      {% endif %}
      
      {% if timeseries_changepoints %}
      <h3>Time Series Change Points</h3>
      <p>Time index used: <code>{{ timeseries_changepoints.time_column }}</code></p>
      <div class="table-container">
        <table>
          <tr><th>Metric</th><th># Breaks</th><th>Change Point Dates</th></tr>
          {% for col, data in timeseries_changepoints.changepoints.items() %}
          <tr>
            <td><code>{{ col }}</code></td>
            <td>{{ data.n_breaks }}</td>
            <td>
              <ul style="margin: 0; padding-left: 20px;">
              {% for d in data.break_dates %}
                <li>{{ d }}</li>
              {% endfor %}
              </ul>
            </td>
          </tr>
          {% endfor %}
        </table>
      </div>
      {% endif %}
    </section>
    {% endif %}


    {% if statistical_tests %}
    <section id="tests">
      <h2>Statistical Testing</h2>
      <div class="health-container" style="padding: 20px;">
        <div style="flex:1;">Total tests run: <strong>{{ statistical_tests.summary.total_tests }}</strong></div>
        <div style="flex:1;">Significant results: <strong>{{ statistical_tests.summary.n_significant }}</strong></div>
      </div>
      {% set sig_tests = [] %}
      {% for test in statistical_tests.results %}{% if test.significant %}{% set _ = sig_tests.append(test) %}{% endif %}{% endfor %}
      
      {% if sig_tests %}
      <div class="table-container">
        <table>
          <tr><th>Test Name</th><th>Column(s)</th><th>Statistic</th><th>p-value</th><th>Effect Size</th><th>Interpretation</th></tr>
          {% for r in sig_tests %}
          <tr>
            <td>{{ r.test_name }}</td>
            <td>
              <code>{{ r.column_a }}</code>
              {% if r.column_b %}<br>× <code>{{ r.column_b }}</code>{% endif %}
            </td>
            <td>{{ '%.4f'|format(r.statistic) }}</td>
            <td>{% if r.p_value >= 0 %}{{ '%.4g'|format(r.p_value) }}{% else %}-{% endif %}</td>
            <td>{% if r.effect_size %}{{ '%.3f'|format(r.effect_size) }} ({{ r.effect_size_label }}){% else %}-{% endif %}</td>
            <td>{{ r.interpretation }}</td>
          </tr>
          {% endfor %}
        </table>
      </div>
      {% else %}
      <p class="empty-note">No statistically significant findings.</p>
      {% endif %}
    </section>
    {% endif %}

    <section id="features">
      <h2>Feature Engineering Suggestions</h2>
      {% if suggestions %}
        <div style="display:flex; flex-direction:column; gap:8px;">
        {% for s in suggestions %}
        <div class="suggestion">
          <span class="action">{{ s.action.replace('_',' ') }}</span>
          {% if s.column %} <code>{{ s.column }}</code> &mdash; {% endif %}
          {{ s.rationale }}
        </div>
        {% endfor %}
        </div>
      {% else %}
      <p class="empty-note">No specific suggestions &mdash; the dataset looks clean.</p>
      {% endif %}
    </section>

  </main>
</div>
<footer>
  <p>{{ final_summary }}</p>
  <p>
    Generated by omni_eda v{{ version }} on {{ generated_at }}.<br>
    Built by <a href="https://github.com/mohd-faizy" target="_blank">GitHub</a> | <a href="https://mohdfaizy.vercel.app/" target="_blank">Mohd Faizy</a>
  </p>
</footer>
</body>
</html>
